"""Flask application for the emotion detector."""

from flask import Flask, request

from EmotionDetection import emotion_detector


app = Flask(__name__)

HOME_PAGE = """
<html>
    <head><title>Emotion Detector</title></head>
    <body>
        <h1>Emotion Detector</h1>
        <form action="/emotionDetector">
            <label for="textToAnalyze">Text to analyze:</label>
            <input
                id="textToAnalyze"
                type="text"
                name="textToAnalyze"
                placeholder="Enter text here"
                style="width: 360px; padding: 6px;"
            >
            <input type="submit" value="Analyze">
        </form>
    </body>
</html>
"""

INVALID_TEXT_MESSAGE = "Invalid text! Please try again!"


@app.route("/")
def home():
    """Show a simple page for testing the application."""
    return HOME_PAGE


def format_emotion_response(response):
    """Create the formatted response text for a successful analysis."""
    return (
        "For the given statement, the system response is "
        f"'anger': {response['anger']}, "
        f"'disgust': {response['disgust']}, "
        f"'fear': {response['fear']}, "
        f"'joy': {response['joy']} and "
        f"'sadness': {response['sadness']}. "
        f"The dominant emotion is {response['dominant_emotion']}."
    )


@app.route("/emotionDetector")
def emotion_detector_route():
    """Analyze the text passed in the query string."""
    text_to_analyze = request.args.get("textToAnalyze", "")

    if not text_to_analyze.strip():
        return INVALID_TEXT_MESSAGE

    response = emotion_detector(text_to_analyze)

    if response["dominant_emotion"] is None:
        return INVALID_TEXT_MESSAGE

    return format_emotion_response(response)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
